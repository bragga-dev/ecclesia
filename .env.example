# =============================================================
# DJANGO
# =============================================================
SECRET_KEY=senha_forte_aqui
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
FRONTEND_URL=http://localhost:3000

# =============================================================
# POSTGRESQL
# =============================================================
POSTGRES_DB=nmeubanco
POSTGRES_USER=usuario_banco
POSTGRES_PASSWORD=senha_forte_aqui
POSTGRES_HOST=db
POSTGRES_PORT=porta_aqui
DATABASE_URL=url_aqui

# =============================================================
# REDIS / CELERY
# =============================================================
REDIS_HOST=redis
REDIS_PORT=porta_aqui
REDIS_URL=url_aqui
CELERY_BROKER_URL=url_aqui
CELERY_RESULT_BACKEND=url_aqui

# =============================================================
# MINIO — credenciais root (só usadas pelo setup-minio)
# =============================================================
MINIO_ROOT_USER=usuario_root_aqui
MINIO_ROOT_PASSWORD=senha_forte_aqui

# =============================================================
# MINIO — usuário IAM da aplicação
# =============================================================
MINIO_APP_USER=usuario_app_aqui
MINIO_APP_PASSWORD=senha_forte_aqui

# =============================================================
# MINIO — buckets e endpoints
# =============================================================
MINIO_BUCKET_MEDIA=dizimus-media
MINIO_BUCKET_STATIC=dizimus-static
MINIO_BUCKET_PRIVATE=dizimus-private
MINIO_ENDPOINT=minio:9000
MINIO_EXTERNAL_URL=http://localhost:9000
MINIO_PUBLIC_URL=localhost:9000

# =============================================================
# AWS / S3 (django-storages — usa o usuário IAM, nunca o root)
# =============================================================
AWS_ACCESS_KEY_ID=dizimus-app
AWS_SECRET_ACCESS_KEY=senha_forte_aqui
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_STORAGE_BUCKET_NAME=dizimus-media
AWS_S3_REGION_NAME=us-east-1
AWS_DEFAULT_ACL=None
AWS_QUERYSTRING_AUTH=False
AWS_S3_FILE_OVERWRITE=False
AWS_S3_VERIFY=False

# =============================================================
# CRYPTOGRAPHY
# =============================================================
FIELD_ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxx

# =============================================================
# EMAIL
# =============================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=email_para_envio_de_emails_aqui
EMAIL_HOST_PASSWORD=senha_de_email_aqui
DEFAULT_FROM_EMAIL=email_para_envio_de_emails_aqui
ADMIN_EMAIL=email_de_admin_aqui

# =============================================================
# ASAAS
# =============================================================
ASAAS_API_KEY=xxxxxxxx
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3