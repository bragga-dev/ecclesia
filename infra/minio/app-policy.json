{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::dizimus-media",
        "arn:aws:s3:::dizimus-media/*",
        "arn:aws:s3:::dizimus-private",
        "arn:aws:s3:::dizimus-private/*"
      ]
    },
    {
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::dizimus-static",
        "arn:aws:s3:::dizimus-static/*"
      ]
    }
  ]
}